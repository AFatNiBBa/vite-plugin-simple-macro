{
	"compilerOptions": {
		// General
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"experimentalDecorators": true,
		"noUncheckedSideEffectImports": true,
		"noImplicitOverride": true,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"noImplicitThis": true,
		"strict": true,

		// Ui
		"types": [ "vite/client" ],
		"jsxImportSource": "solid-js",
		"jsx": "preserve",

		// Extra
		"paths": {
			"~/*": [ "./src/*" ]
		}
	}
}